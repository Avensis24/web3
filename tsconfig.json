{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "declaration": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["hardhat.config.ts", "scripts/**/*.ts", "test/**/*.ts", "contracts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
